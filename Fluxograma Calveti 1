## 💻 Código Java

public class VelocidadeMedia {
    public static void main(String[] args) {

        // Valores definidos
        double distancia = 150.0; // km
        double tempo = 2.0;       // horas

        // Cálculo
        double velocidade = distancia / tempo;

        // Resultado
        System.out.printf("Velocidade média: %.2f km/h%n", velocidade);
    }
}
