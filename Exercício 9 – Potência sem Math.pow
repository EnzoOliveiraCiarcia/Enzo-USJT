import java.util.Scanner;

// Exercício 9 – Potência
public class Ex9 {
    public static void main(String[] args) {

        Scanner sc = new Scanner(System.in);
        int a = sc.nextInt();
        int b = sc.nextInt();
        int resultado = 1;

        for (int i = 0; i < b; i++) {
            resultado *= a;
        }

        System.out.println(resultado);

        sc.close();
    }
}
