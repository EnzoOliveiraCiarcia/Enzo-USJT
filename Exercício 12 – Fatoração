import java.util.Scanner;

// Exercício 12 – Fatoração
public class Ex12 {
    public static void main(String[] args) {

        Scanner sc = new Scanner(System.in);
        int n = sc.nextInt();

        do {
            for (int i = 2; i <= n; i++) {
                if (n % i == 0) {
                    System.out.println(i);
                    n /= i;
                    break;
                }
            }
        } while (n > 1);

        sc.close();
    }
}
