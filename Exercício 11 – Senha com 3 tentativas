import java.util.Scanner;

// Exercício 11 – Validação de senha
public class Ex11 {
    public static void main(String[] args) {

        Scanner sc = new Scanner(System.in);
        String senha;

        for (int i = 0; i < 3; i++) {

            do {
                System.out.print("Digite senha (4 dígitos): ");
                senha = sc.next();
            } while (senha.length() != 4);

        }

        sc.close();
    }
}
